# Environment
NODE_ENV=development
PORT=5001

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=novasathi_super_secret_jwt_key_2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=novasathi_refresh_secret_2026
JWT_REFRESH_EXPIRES_IN=30d

# OTP (SMS Gateway — placeholder for production)
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Platform Settings
FREE_MINUTES_SIGNUP=5
FREE_MINUTES_DAILY_SOS=10
PLATFORM_COMMISSION_PERCENT=30

# Encryption
ENCRYPTION_KEY=novasathi_enc_key_32_chars_long!

# Frontend URL (Must be the exact production domain in live environment)
CLIENT_URL=http://localhost:5173

# Firebase (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
